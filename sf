<!DOCTYPE html>
<html>
<head>
    <title>DS Player</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { background: #000; color: #fff; text-align: center; font-family: sans-serif; }
        #game { width: 100vw; height: 100vh; }
        .setup { padding: 50px; }
    </style>
</head>
<body>

    <div id="setup-area" class="setup">
        <h1>DS PLAYER</h1>
        <p>1. Select your .nds file:</p>
        <input type="file" id="file-input" accept=".nds">
        <br><br>
        <button id="start-btn" style="display:none; padding: 15px 30px; font-size: 20px;">CLICK TO START GAME</button>
    </div>

    <div id="game"></div>

    <script>
        let selectedFile = null;

        // 1. Capture the file when you pick it
        document.getElementById('file-input').onchange = function(e) {
            selectedFile = e.target.files[0];
            if (selectedFile) {
                document.getElementById('start-btn').style.display = 'inline-block';
            }
        };

        // 2. Launch the emulator only when button is clicked
        document.getElementById('start-btn').onclick = function() {
            // Hide the setup UI
            document.getElementById('setup-area').style.display = 'none';

            // Set configuration
            window.EJS_player = '#game';
            window.EJS_core = 'nds';
            window.EJS_gameUrl = URL.createObjectURL(selectedFile);
            window.EJS_pathtodata = 'https://cdn.emulatorjs.org/stable/data/';

            // Load the engine
            const script = document.createElement('script');
            script.src = 'https://cdn.emulatorjs.org/stable/data/loader.js';
            document.head.appendChild(script);
        };
    </script>
</body>
</html>
