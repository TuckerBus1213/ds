<!DOCTYPE html>
<html>
<head>
    <title>My DS Player</title>
    <style>
        body { background: #1a1a1a; color: white; font-family: sans-serif; text-align: center; }
        #player { width: 100%; height: 80vh; border: none; }
        .controls { margin: 20px; padding: 20px; border: 1px solid #444; border-radius: 8px; }
    </style>
</head>
<body>
    <h1>DS Emulator</h1>
    <div class="controls">
        <p>Select your .nds file from your Chromebook:</p>
        <input type="file" id="rom-input" accept=".nds">
    </div>

    <div id="game"></div>

    <script>
        // This tells EmulatorJS how to behave
        window.EJS_player = '#game';
        window.EJS_core = 'nds'; 
        window.EJS_pathtodata = 'https://cdn.emulatorjs.org/stable/data/'; // Loads engine from CDN

        document.getElementById('rom-input').onchange = function(e) {
            const file = e.target.files[0];
            if (file) {
                window.EJS_gameUrl = URL.createObjectURL(file); // Turn local file into a link
                
                // Load the loader script dynamically
                const loader = document.createElement('script');
                loader.src = 'https://cdn.emulatorjs.org/stable/data/loader.js';
                document.head.appendChild(loader);
            }
        };
    </script>
</body>
</html>
